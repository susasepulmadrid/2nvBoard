# Configuración del servidor 2NVBoard
PORT=4000

# Base de datos PostgreSQL — opción A: cadena de conexión
# DATABASE_URL=postgres://usuario:clave@localhost:5432/2nvboard

# Base de datos PostgreSQL — opción B: variables sueltas
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=2nvboard

# Clave secreta para firmar los tokens JWT (CÁMBIALA en producción)
JWT_SECRET=cambia-esta-clave-por-una-larga-y-aleatoria
